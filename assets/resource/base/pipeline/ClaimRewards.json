            "param": {
                "roi": [
                    44,
                    94,
                    55,
                    532
                ],
                "template": [
                    "Common/Scene/ExplorationGuide/Page2.png",
                    "Common/Scene/ExplorationGuide/Page2White.png",
                    "Common/Scene/ExplorationGuide/Page2WithRedDot.png",
                    "Common/Scene/ExplorationGuide/Page2WhiteWithRedDot.png"

        "desc": "开始领取活跃度奖励",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWorld"
                ]
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": [
                    112
                ]
            }
        },
        "next": [
            "ClaimRewardsActivitySwitchToPage2"
        ]
    },
